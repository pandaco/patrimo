# ─── App ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=3333
# Comma-separated list of allowed CORS origins (no trailing slash).
FRONTEND_URL=http://localhost:4200

# ─── Database (PostgreSQL via docker-compose) ──────────────────
# REQUIRED. Credentials match docker-compose.yml — no need to change for local dev.
# Used by both the runtime API and the TypeORM CLI (db:migrate, db:seed).
DATABASE_URL=postgres://patrimo:patrimo@localhost:5432/patrimo

# ─── Cache (Redis via docker-compose, optional for early dev) ──
REDIS_URL=redis://localhost:6379

# ─── Auth — JWT (réservé pour API tokens futurs) ───────────────
# REQUIRED. Generate a strong secret (≥ 32 chars). NEVER commit a real value.
#   openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ─── Auth — Sessions (cookie signé HttpOnly) ───────────────────
# REQUIRED. Signs the BFF session cookie. Min 32 chars.
#   openssl rand -base64 48
SESSION_SECRET=

# ─── Auth — Google OAuth2 (BFF) ────────────────────────────────
# Get these by following docs/dev-setup.md → "Configurer Google OAuth".
# Leave the defaults to boot the API without OAuth (login button will fail).
GOOGLE_CLIENT_ID=configure-me
GOOGLE_CLIENT_SECRET=configure-me
GOOGLE_CALLBACK_URL=http://localhost:3333/api/auth/google/callback
# Comma-separated whitelist for single-user MVP. Empty = allow any Google account.
GOOGLE_ALLOWED_EMAILS=
