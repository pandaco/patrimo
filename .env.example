# =========================
# General
# =========================
NODE_ENV=development
PORT=3333

# =========================
# Database — choose ONE mode
# =========================
# Default: SQLite (no install required, file in /tmp)
DB_TYPE=sqlite
SQLITE_PATH=./tmp/patrimo.db

# To switch to PostgreSQL: set DB_TYPE=postgres and start docker-compose
# DB_TYPE=postgres
PG_HOST=localhost
PG_PORT=5432
PG_DB=patrimo
PG_USER=patrimo
PG_PASSWORD=patrimo

# =========================
# Cache (Redis)
# =========================
# In-memory cache is fine for early dev; Redis recommended once free APIs are hit.
CACHE_TYPE=memory          # memory | redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL_PRICE=900        # 15 min for live prices
REDIS_TTL_FX=86400         # 24 h for FX rates
REDIS_TTL_METADATA=2592000 # 30 days for ETF metadata

# =========================
# Market data providers (free)
# =========================
PRICE_PROVIDER=yahoo       # yahoo | stooq
CRYPTO_PROVIDER=coingecko  # coingecko | coincap
FX_PROVIDER=frankfurter    # frankfurter | exchangerate-host

# =========================
# Auth — Google OAuth2 (BFF pattern) — see tmp/auth.md
# =========================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3333/api/v1/auth/google/callback
GOOGLE_SCOPES=openid,email,profile
GOOGLE_ALLOWED_EMAILS=                    # single-user MVP whitelist (comma-separated)

# Session (opaque cookie + Redis store)
SESSION_COOKIE_NAME=__Host-session
SESSION_COOKIE_SECURE=false               # true in prod (HTTPS only)
SESSION_COOKIE_DOMAIN=                    # empty in dev
SESSION_TTL_SECONDS=604800                # 7 days
SESSION_SLIDING=true

# AES-256-GCM key (32 raw bytes, base64) — encrypts oauth_account tokens at rest
OAUTH_TOKEN_ENC_KEY=
OAUTH_TOKEN_ENC_KEY_OLD=                  # previous key after rotation

# =========================
# Logging
# =========================
LOG_LEVEL=info             # debug | info | warn | error
